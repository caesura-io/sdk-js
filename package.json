{
  "name": "@caesura/sdk-js",
  "private": true,
  "version": "0.0.0",
  "description": "Caesura SDKs for JavaScript/TypeScript AI frameworks",
  "type": "module",
  "engines": {
    "node": ">=18.17"
  },
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm -r --parallel dev",
    "lint": "eslint .",
    "format": "prettier --write .",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "pnpm build && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.9",
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.7.0",
    "eslint": "^9.12.0",
    "prettier": "^3.3.3",
    "typescript": "^5.6.2",
    "typescript-eslint": "^8.61.1"
  }
}