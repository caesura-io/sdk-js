{
  "name": "@caesura-io/openai",
  "version": "0.1.0",
  "description": "Transparent proxy wrapper for the official OpenAI SDK to inject Caesura recommendations.",
  "license": "Apache-2.0",
  "author": "Caesura",
  "homepage": "https://github.com/caesura-io/sdk-js/tree/main/packages/openai#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/caesura-io/sdk-js.git",
    "directory": "packages/openai"
  },
  "bugs": {
    "url": "https://github.com/caesura-io/sdk-js/issues"
  },
  "keywords": [
    "caesura",
    "ai",
    "llm",
    "recommendations",
    "openai"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@caesura-io/core": "workspace:*"
  },
  "peerDependencies": {
    "openai": ">=4.77.0"
  },
  "devDependencies": {
    "openai": "^4.77.0",
    "tsup": "^8.3.0",
    "typescript": "^5.6.2",
    "vitest": "^2.1.2"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
