{
  "name": "@caesura/ai-sdk",
  "version": "0.0.0",
  "description": "Caesura adapter for the Vercel AI SDK — asynchronous, non-blocking recommendation injection via language model middleware.",
  "license": "MIT",
  "author": "Caesura",
  "homepage": "https://github.com/caesura-io/caesura-sdk-js/tree/main/packages/ai-sdk#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/caesura-io/caesura-sdk-js.git",
    "directory": "packages/ai-sdk"
  },
  "bugs": {
    "url": "https://github.com/caesura-io/caesura-sdk-js/issues"
  },
  "keywords": [
    "caesura",
    "ai",
    "ai-sdk",
    "vercel-ai-sdk",
    "llm",
    "agents",
    "middleware",
    "recommendations"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "peerDependencies": {
    "ai": "^5.0.0 || ^6.0.0"
  },
  "devDependencies": {
    "ai": "^6.0.0",
    "tsup": "^8.3.0",
    "typescript": "^5.6.2",
    "vitest": "^2.1.2"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}